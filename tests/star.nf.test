nextflow_pipeline {

    name "Test pipeline with STAR aligner"
    script "../main.nf"
    tag "star"

    test("star") {

        when {
            params {
                outdir = "$outputDir"
                aligner = "star"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore', ignore: ['multiqc/**/mqc_picard_quality_*.txt', 'multiqc/**/mqc_read_distribution_profile_1.txt'])

            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we test pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_atacseq_software_mqc_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    test("star with stub") {

        options "-stub"

        when {
            params {
                outdir = "$outputDir"
                aligner = "star"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.trace.succeeded().size()
                ).match() }
            )
        }
    }
}
